# Copier en .env et adapter les valeurs
# Ne jamais commiter .env
#
# Ce fichier couvre le développement local (compose.yml, variables d'environnement en clair).
# En production, ces valeurs sont injectées via Docker secrets (profil Spring `prod` +
# docker-compose.prod.yml) — jamais via .env. Détail complet du mécanisme, table des secrets
# et procédure de rotation : docs/deployment/secret-management.md (EN07.2).

# PostgreSQL
POSTGRES_PASSWORD=pivot_dev

# CORS
CORS_ALLOWED_ORIGINS=http://localhost

# Mail — dev : Mailpit sur localhost:1025 (UI : http://localhost:8025)
# prod : configurer un vrai SMTP
MAIL_USERNAME=pivot@localhost
MAIL_PASSWORD=
MAIL_FROM=noreply@pivot.app
APP_URL=http://localhost

# Email support (affiché dans les emails de sécurité)
PIVOT_SUPPORT_EMAIL=support@pivot.app

# Email du propriétaire / destinataire des formulaires de contact
PIVOT_OWNER_MAIL=owner@pivot.app

# Auth — TTL reset, TTL OTP appareil, durée confiance appareil : configurables
# dans l'interface d'administration (table feature_flags) — pas de variable d'environnement.

# Auth — Clé HMAC pour les OTP appareil (min 32 chars, obligatoire en production)
# Si absent : clé éphémère générée au démarrage (OTP invalidés à chaque restart)
PIVOT_AUTH_OTP_SECRET=change-me-in-production-minimum-32-characters-long

# Redis — vide par défaut (pas d'AUTH en dev). Renseigner uniquement si l'instance Redis
# locale/partagée exige un mot de passe.
SPRING_DATA_REDIS_PASSWORD=

# OIDC (optionnel — multi-tenant enterprise)
OIDC_ISSUER_URI=

# --- Production uniquement (docker-compose.prod.yml) ---
# Aucune des variables ci-dessus n'est utilisée en prod : le profil Spring `prod` lit les
# équivalents via Docker secrets (fichiers sous SECRET_FILE_PATH, défaut /run/secrets).
# Voir docs/deployment/secret-management.md pour la table complète et la procédure de rotation.
# SECRET_FILE_PATH=/run/secrets
