# Copier en .env et adapter les valeurs
# Ne jamais commiter .env

# PostgreSQL
POSTGRES_PASSWORD=pivot_dev

# CORS
CORS_ALLOWED_ORIGINS=http://localhost

# Mail — dev : Mailpit sur localhost:1025 (UI : http://localhost:8025)
# prod : configurer un vrai SMTP
MAIL_USERNAME=pivot@localhost
MAIL_PASSWORD=
MAIL_FROM=noreply@pivot.app
APP_URL=http://localhost

# Email support (affiché dans les emails de sécurité)
PIVOT_SUPPORT_EMAIL=support@pivot.app

# Auth — TTL reset, TTL OTP appareil, durée confiance appareil : configurables
# dans l'interface d'administration (table feature_flags) — pas de variable d'environnement.

# Auth — Clé HMAC pour les OTP appareil (min 32 chars, obligatoire en production)
# Si absent : clé éphémère générée au démarrage (OTP invalidés à chaque restart)
PIVOT_AUTH_OTP_SECRET=change-me-in-production-minimum-32-characters-long

# OIDC (optionnel — multi-tenant enterprise)
OIDC_ISSUER_URI=
