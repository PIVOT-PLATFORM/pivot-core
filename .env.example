# Copier en .env et adapter les valeurs
# Ne jamais commiter .env

# PostgreSQL
POSTGRES_PASSWORD=pivot_dev

# JWT — minimum 64 caractères, obligatoire en production
JWT_SECRET=change-me-in-production-minimum-64-characters-long-pivot-secret-key

# CORS
CORS_ALLOWED_ORIGINS=http://localhost

# OIDC (optionnel — laisser vide pour mode JWT local uniquement)
OIDC_ISSUER_URI=

# Mail — dev : Mailpit sur localhost:1025 (UI : http://localhost:8025)
# prod : configurer un vrai SMTP
MAIL_USERNAME=pivot@localhost
MAIL_PASSWORD=
MAIL_FROM=noreply@pivot.app
APP_URL=http://localhost
