<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                    https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

    <!--
        EI_EXPOSE_REP / EI_EXPOSE_REP2:
          - JPA entities require mutable getters/setters for the persistence provider
            (Hibernate); defensive copies would break dirty-checking.
          - Spring components (services, controllers, filters, config) store
            constructor-injected singleton beans (e.g. CookieHelper). These are container-
            managed, not externally-mutable state — copying them is meaningless.
        Intentional design decisions, not bugs.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Or>
            <Package name="fr.pivot.auth.entity"/>
            <Package name="fr.pivot.tenant.entity"/>
            <Package name="fr.pivot.auth.service"/>
            <Package name="fr.pivot.auth.controller"/>
            <Package name="fr.pivot.auth.config"/>
            <Package name="fr.pivot.config"/>
            <Package name="fr.pivot.auth.filter"/>
            <Package name="fr.pivot.auth.scheduler"/>
            <Package name="fr.pivot.scheduler"/>
            <!-- Module system : ModuleActivationService stocke des beans singleton injectés
                 (repository, registry, publisher) ; ModuleActivation est une entité JPA. -->
            <Package name="fr.pivot.core.modules"/>
            <!-- Cache Redis (EN03.3) : ModuleActivationCacheService stocke des beans
                 singleton injectés (StringRedisTemplate, MeterRegistry, ModuleActivationService). -->
            <Package name="fr.pivot.core.modules.cache"/>
            <!-- Contrôleurs REST du registre de modules (ModuleController, AdminModuleController) :
                 stockent des beans singleton constructeur-injectés (ModuleRegistryService,
                 AdminModuleActivationService, ModuleActivationService, ModuleRegistry, AuditService,
                 CookieHelper). -->
            <Package name="fr.pivot.modules.api"/>
            <!-- US02.1.1 — AccountController/ProfileService/AvatarStorageService stockent des
                 beans singleton constructeur-injectés (ProfileService, AuditService,
                 CookieHelper, UserRepository, AvatarStorageService, AvatarStorageProperties —
                 record de configuration immuable). -->
            <!-- Export de données personnelles (RGPD Art. 20, US02.3.1) : DataExportRequest est
                 une entité JPA (getters/setters mutables requis par Hibernate) ; le service et le
                 contrôleur stockent des beans singleton constructeur-injectés (repositories,
                 AuditService, EmailService, ExportArchiveBuilder, ExportStorageService,
                 CookieHelper) ; ExportBundle est un porteur de données interne (record) qui
                 expose des listes déjà considérées immuables côté appelant. -->
            <Package name="fr.pivot.account.controller"/>
            <Package name="fr.pivot.account.service"/>
            <Package name="fr.pivot.account.config"/>
            <Package name="fr.pivot.account.entity"/>
            <Package name="fr.pivot.account.scheduler"/>
            <!-- Gestion plateforme des tenants (SuperAdminTenantController, US06.2.1/US06.2.2/US06.2.3) :
                 stocke des beans singleton constructeur-injectés (SuperAdminTenantService,
                 CookieHelper, TenantRepository, UserRepository, RateLimiterService,
                 AuditService). -->
            <Package name="fr.pivot.tenant.api"/>
            <!-- Plans commerciaux/tarifaires (SuperAdminPlanController, US03.3.1) : Plan est une
                 entité JPA (getters/setters mutables requis par Hibernate, y compris le Set de
                 module ids porté par @ElementCollection) ; PlanService stocke des beans singleton
                 constructeur-injectés (PlanRepository, ModuleRegistry). -->
            <Package name="fr.pivot.plan.entity"/>
            <Package name="fr.pivot.plan.api"/>
            <!-- Infrastructure notifications in-app (EN-NOTIF) : Notification est une entité JPA
                 (getters/setters mutables requis par Hibernate) ; NotificationService/
                 NotificationController/NotificationPushListener stockent des beans singleton
                 constructeur-injectés (repositories, MessageSource, ApplicationEventPublisher,
                 SimpMessagingTemplate) ; NotificationWebSocketConfig/StompAuthChannelInterceptor
                 stockent de même des beans singleton constructeur-injectés (TokenService,
                 intercepteur, chaîne d'origines CORS). -->
            <Package name="fr.pivot.notification.entity"/>
            <Package name="fr.pivot.notification.service"/>
            <Package name="fr.pivot.notification.controller"/>
            <Package name="fr.pivot.notification.config"/>
            <Package name="fr.pivot.notification.listener"/>
        </Or>
    </Match>

    <!--
        EN53.1 (modulith Vague 1) — module agilite absorbé dans pivot-core. Report des
        exclusions EI_EXPOSE_REP/EI_EXPOSE_REP2 que portait le spotbugs-exclude.xml propre à
        pivot-agilite-core (entités JPA à getters/setters mutables requis par Hibernate, beans
        singleton constructeur-injectés, et DTO records exposant des List/Map déjà immuables —
        ex. RoomResponse.cardValues = PokerCardDeck.FIBONACCI_VALUES List.of(...) constant).
        Même justification centralisée que les packages shell ci-dessus (ADR-022, CLAUDE.md :
        exclusion centralisée en config, jamais de suppression inline).
        NB : fr.pivot.agilite.auth(.entity) — la revalidation de token dupliquée y a été retirée
        (EN53.1, fusion sur le TokenService partagé) ; l'exclusion subsiste sans dommage si le
        package est vide côté main.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Or>
            <Package name="fr.pivot.agilite.poker.ws"/>
            <Package name="fr.pivot.agilite.ws"/>
            <Package name="fr.pivot.agilite.auth"/>
            <Package name="fr.pivot.agilite.auth.entity"/>
            <Package name="fr.pivot.agilite.context"/>
            <Package name="fr.pivot.agilite.config"/>
            <Package name="fr.pivot.agilite.exception"/>
            <Package name="fr.pivot.agilite.retro.session"/>
            <Package name="fr.pivot.agilite.retro.session.dto"/>
            <Package name="fr.pivot.agilite.retro.format"/>
            <Package name="fr.pivot.agilite.retro.format.dto"/>
            <Package name="fr.pivot.agilite.poker"/>
            <Package name="fr.pivot.agilite.poker.dto"/>
            <Package name="fr.pivot.agilite.wheel"/>
            <Package name="fr.pivot.agilite.wheel.dto"/>
            <Package name="fr.pivot.agilite.team"/>
            <Package name="fr.pivot.agilite.team.dto"/>
            <Package name="fr.pivot.agilite.retro.card"/>
            <Package name="fr.pivot.agilite.retro.card.ws"/>
            <Package name="fr.pivot.agilite.retro.phase"/>
            <Package name="fr.pivot.agilite.retro.ws"/>
            <Package name="fr.pivot.agilite.retro.phase.dto"/>
            <Package name="fr.pivot.agilite.retro.vote"/>
            <Package name="fr.pivot.agilite.retro.vote.dto"/>
            <Package name="fr.pivot.agilite.retro.vote.ws"/>
            <Package name="fr.pivot.agilite.poker.ticket"/>
            <Package name="fr.pivot.agilite.poker.ticket.dto"/>
            <Package name="fr.pivot.agilite.poker.vote"/>
            <Package name="fr.pivot.agilite.poker.vote.dto"/>
            <Package name="fr.pivot.agilite.poker.vote.ws"/>
            <Package name="fr.pivot.agilite.wheel.ws"/>
            <Package name="fr.pivot.agilite.retro.action"/>
            <Package name="fr.pivot.agilite.retro.action.dto"/>
            <!-- E11 Capacity Planning : CapacityEvent est une entité JPA (getters/setters
                 mutables requis par Hibernate, y compris working_days Integer[]) ; les DTO
                 records (CapacityEventInput, CapacityMemberInput, EventCapacityResult) exposent
                 des List/Set/Map déjà considérées immuables côté appelant. Même justification
                 centralisée que les packages agilite ci-dessus (ADR-022, CLAUDE.md). -->
            <Package name="fr.pivot.agilite.capacity"/>
            <Package name="fr.pivot.agilite.capacity.dto"/>
            <!-- E11 Capacity Planning (Vague 2 enablers) : mêmes justifications — DTO records
                 exposant List/Map (KpiResponse, CapacityRgpdExportResponse), contrôleurs REST
                 stockant des services singleton constructeur-injectés (CapacityRgpdController),
                 connecteurs/événements/cadence. Exclusion centralisée (ADR-022, CLAUDE.md). -->
            <Package name="fr.pivot.agilite.capacity.connector"/>
            <Package name="fr.pivot.agilite.capacity.kpi"/>
            <Package name="fr.pivot.agilite.capacity.kpi.dto"/>
            <Package name="fr.pivot.agilite.capacity.event"/>
            <Package name="fr.pivot.agilite.capacity.rgpd"/>
            <Package name="fr.pivot.agilite.capacity.cadence"/>
        </Or>
    </Match>

    <!--
        EN53.2 (modulith Vague 2) — module collaboratif absorbé dans pivot-core. Report des
        exclusions EI_EXPOSE_REP/EI_EXPOSE_REP2 que portait le spotbugs-exclude.xml propre à
        pivot-collaboratif-core (entités JPA à getters/setters mutables requis par Hibernate,
        beans singleton constructeur-injectés, et DTO records exposant des List/Map déjà
        considérées immuables côté appelant). Même justification centralisée que les packages
        shell et agilite ci-dessus (ADR-022, CLAUDE.md : exclusion centralisée en config, jamais
        de suppression inline).
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Or>
            <!-- Module Collaboratif — Whiteboard (US08.1.x) :
                 JPA entities (Board, BoardMember) require mutable getters/setters for Hibernate;
                 service (BoardService) and controller (BoardController) store constructor-injected
                 singleton beans (repositories, WhiteboardModuleCheck). -->
            <Package name="fr.pivot.collaboratif.whiteboard.board"/>
            <Package name="fr.pivot.collaboratif.whiteboard.board.dto"/>
            <!-- US08.2.1 — BoardShareService/BoardShareController store constructor-injected
                 singleton beans (repositories, StringRedisTemplate, @Value String). -->
            <Package name="fr.pivot.collaboratif.whiteboard.share"/>
            <Package name="fr.pivot.collaboratif.whiteboard.share.dto"/>
            <!-- US08.2.2 — BoardJoinService/BoardJoinController/JoinRateLimitService store
                 constructor-injected singleton beans (repositories, StringRedisTemplate). -->
            <Package name="fr.pivot.collaboratif.whiteboard.join"/>
            <Package name="fr.pivot.collaboratif.whiteboard.join.dto"/>
            <!-- US08.2.3 — BoardMemberService/BoardMemberController store constructor-injected
                 singleton beans (repositories). -->
            <Package name="fr.pivot.collaboratif.whiteboard.member"/>
            <Package name="fr.pivot.collaboratif.whiteboard.member.dto"/>
            <!-- EN08.1 — WebSocket STOMP isolation: MembershipCacheService, WhiteboardChannelInterceptor,
                 WhiteboardPresenceRegistry store constructor-injected singleton beans (repositories,
                 StringRedisTemplate, SimpMessagingTemplate); PresencePayload is a DTO record used
                 for STOMP broadcasting (mutable List is intentional — JSON-serialised by the broker). -->
            <Package name="fr.pivot.collaboratif.whiteboard.ws"/>
            <!-- US08.3.1 — Canvas WS actions: CanvasActionService, ParticipantMetaStore, ColorPaletteService,
                 WhiteboardActionController store constructor-injected singleton beans (repository, messaging
                 template, ObjectMapper, MeterRegistry); DTO records expose mutable Map/List for JSON transport. -->
            <Package name="fr.pivot.collaboratif.whiteboard.canvas"/>
            <Package name="fr.pivot.collaboratif.whiteboard.canvas.dto"/>
            <!-- US08.6.6 — TABLE card content sanitisation: TableCardContentSanitizer stores a
                 constructor-injected singleton bean (the shared Jackson 3 ObjectMapper), same
                 rationale as the parent fr.pivot.collaboratif.whiteboard.canvas package above. -->
            <Package name="fr.pivot.collaboratif.whiteboard.canvas.table"/>
            <!-- US08.4.1 — Board-from-template: WhiteboardTemplateService/WhiteboardTemplateController
                 store constructor-injected singleton beans (repositories, CanvasElementValidator,
                 WhiteboardModuleCheck); WhiteboardTemplate/WhiteboardTemplateElement are JPA
                 entities (mutable state required by Hibernate, even though read-only from the
                 application's point of view — rows are Flyway-seeded only). -->
            <Package name="fr.pivot.collaboratif.whiteboard.template"/>
            <Package name="fr.pivot.collaboratif.whiteboard.template.dto"/>
            <!-- Vote / dot-voting — VoteActionService/VoteQueryService/VoteController store
                 constructor-injected singleton beans (repositories, SimpMessagingTemplate,
                 ObjectMapper); VoteSession/Vote are JPA entities (mutable state required by
                 Hibernate); VoteSessionResponse/VoteResponse are DTO records that expose mutable
                 List for JSON transport (same rationale as the canvas.dto package above). -->
            <Package name="fr.pivot.collaboratif.whiteboard.vote"/>
            <Package name="fr.pivot.collaboratif.whiteboard.vote.dto"/>
            <!-- US08.13.1 — Klaxoon import + undo: WhiteboardImportService/WhiteboardImportController/
                 ImportRateLimitService/ImportBodySizeLimitFilter store constructor-injected singleton
                 beans (repositories, StringRedisTemplate, SimpMessagingTemplate via WhiteboardBroadcastService,
                 ObjectMapper); DTO records (request/response/broadcast payloads) expose mutable List
                 for JSON transport (same rationale as the canvas.dto package above). -->
            <Package name="fr.pivot.collaboratif.whiteboard.importer"/>
            <Package name="fr.pivot.collaboratif.whiteboard.importer.dto"/>
            <Package name="fr.pivot.collaboratif.context"/>
            <Package name="fr.pivot.collaboratif.config"/>
            <Package name="fr.pivot.collaboratif.exception"/>
        </Or>
    </Match>

</FindBugsFilter>
